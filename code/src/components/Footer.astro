---
import { siteConfig } from '../site.config';
const year = new Date().getFullYear();
---

<footer class="border-t border-border/60 bg-muted/30">
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="font-serif text-sm font-medium text-foreground">{siteConfig.name}</p>
        <p class="mt-1 max-w-md text-sm text-muted-foreground">{siteConfig.tagline}</p>
      </div>
      <p class="text-xs text-muted-foreground">© {year} · {siteConfig.footerNote}</p>
    </div>
  </div>
</footer>
