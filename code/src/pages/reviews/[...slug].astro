---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { Badge } from '@/components/ui/badge';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { formatDate } from '@/lib/utils';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews', ({ data }) => !data.draft);
  const notes = await getCollection('notes', ({ data }) => !data.draft);

  return reviews.map((review) => ({
    params: { slug: review.id },
    props: { review, notes },
  }));
}

const { review, notes } = Astro.props;
const { Content } = await render(review);

const relatedItems = review.data.relatedNotes
  .map((id) => notes.find((n) => n.id === id))
  .filter(Boolean)
  .map((note) => ({
    href: `/notes/${note!.id}`,
    title: note!.data.title,
    description: note!.data.description,
    type: 'note' as const,
  }));

const summarySections = [
  { key: 'change', label: '外部变化', heading: '这期揭示了什么外部变化' },
  { key: 'insight', label: '定位启发', heading: '对个人重新定位的启发' },
  { key: 'concepts', label: '概念案例', heading: '值得保留的概念或案例' },
  { key: 'action', label: '行动建议', heading: '可转化的自测问题或行动建议' },
];
---

<BaseLayout title={review.data.title} description={review.data.description}>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
    <header class="mb-10 border-b border-border/60 pb-8">
      <div class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
        <span>{formatDate(review.data.publishedAt)}</span>
        <span>·</span>
        <span>{review.data.source}</span>
        {
          review.data.guest && (
            <>
              <span>·</span>
              <span>嘉宾：{review.data.guest}</span>
            </>
          )
        }
        {
          review.data.sourceUrl && (
            <a
              href={review.data.sourceUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-primary hover:underline"
            >
              原节目 ↗
            </a>
          )
        }
      </div>
      <h1 class="mt-3 font-serif text-3xl font-semibold leading-tight tracking-tight sm:text-4xl">
        {review.data.title}
      </h1>
      <p class="mt-4 text-lg text-muted-foreground leading-relaxed">{review.data.description}</p>
      {
        review.data.tags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {review.data.tags.map((tag) => (
              <Badge variant="secondary">{tag}</Badge>
            ))}
          </div>
        )
      }
    </header>

    <div class="mb-10 grid gap-3 sm:grid-cols-2">
      {
        summarySections.map((section) => (
          <Card class="border-primary/10 bg-primary/[0.02]">
            <CardHeader class="pb-2">
              <CardTitle class="text-sm font-medium text-primary">{section.label}</CardTitle>
            </CardHeader>
            <CardContent class="text-xs text-muted-foreground">见正文「{section.heading}」</CardContent>
          </Card>
        ))
      }
    </div>

    <div class="prose">
      <Content />
    </div>
    <RelatedLinks items={relatedItems} heading="相关研究笔记" />
  </article>
</BaseLayout>
