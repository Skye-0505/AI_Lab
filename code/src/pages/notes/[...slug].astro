---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { Badge } from '@/components/ui/badge';
import { formatDate } from '@/lib/utils';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  const reviews = await getCollection('reviews', ({ data }) => !data.draft);

  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note, reviews },
  }));
}

const { note, reviews } = Astro.props;
const { Content } = await render(note);

const relatedItems = note.data.relatedReviews
  .map((id) => reviews.find((r) => r.id === id))
  .filter(Boolean)
  .map((review) => ({
    href: `/reviews/${review!.id}`,
    title: review!.data.title,
    description: review!.data.description,
    type: 'review' as const,
  }));
---

<BaseLayout title={note.data.title} description={note.data.description}>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
    <header class="mb-10 border-b border-border/60 pb-8">
      <p class="text-sm text-muted-foreground">{formatDate(note.data.publishedAt)}</p>
      <h1 class="mt-3 font-serif text-3xl font-semibold leading-tight tracking-tight sm:text-4xl">
        {note.data.title}
      </h1>
      <p class="mt-4 text-lg text-muted-foreground leading-relaxed">{note.data.description}</p>
      {
        note.data.tags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {note.data.tags.map((tag) => (
              <Badge variant="secondary">{tag}</Badge>
            ))}
          </div>
        )
      }
    </header>
    <div class="prose">
      <Content />
    </div>
    <RelatedLinks items={relatedItems} heading="相关访谈复盘" />
  </article>
</BaseLayout>
